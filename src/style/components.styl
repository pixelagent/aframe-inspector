        color: var(--color-primary-content)

  .class-available
    margin-top: 4px
    padding-top: 4px
    border-top: 1px solid var(--color-base-300)

    .class-available-label
      color: var(--color-base-content)
      font-size: 10px
      opacity: 0.7
      margin-bottom: 4px

    .class-available-items
      display: flex
      flex-wrap: wrap
      gap: 4px

    .class-available-item
      background: var(--color-base-100)
      border: 1px solid var(--color-base-300)
      border-radius: 4px
      color: var(--color-base-content)
      cursor: pointer
      font-size: 11px
      padding: 2px 6px
      transition: all 0.2s

      &:hover
        background: var(--color-primary)
        border-color: var(--color-primary)
        color: var(--color-primary-content)

// Available class select dropdown
.class-available-select
  margin-top: 8px

  .select__control
    background: var(--color-base-300)
    border: 1px solid var(--color-base-300)
    border-radius: 4px
    min-height: 26px

    &:hover
      border-color: var(--color-base-300)

  .select__placeholder
    color: var(--color-base-content)
    opacity: 0.6

  .select__input
    color: var(--color-base-content)

  .select__single-value
    color: var(--color-primary)

  .select__menu
    background: var(--color-base-200)
    border: 1px solid var(--color-base-300)

  .select__option
    color: var(--color-base-content)
    cursor: pointer

    &:hover
      background: var(--color-base-lighter)

    &--is-selected
      background: var(--color-primary)
      color: var(--color-primary-content)
