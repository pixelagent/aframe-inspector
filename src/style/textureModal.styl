.modal
  animation animateopacity 0.2s ease-out
  background-color rgba(0, 0, 0, 0.6)
  display flex
  height 100%
  left 0
  overflow auto
  position fixed
  top 0
  width 100%
  z-index 9999999999

// Component Help Modal specific styling - centered with margins
#componentHelpModal
  .modal-content
    background-color: var(--color-base-100)
    border-radius: 8px
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6)
    left: 50%
    margin: 30px auto
    max-width: 480px
    transform: translateX(-50%)
    width: 90%

  .modal-header
    background-color: var(--color-base-200)
    border-bottom: 1px solid var(--color-base-300)
    border-radius: 8px 8px 0 0

  .modal-body
    background-color: var(--color-base-100)
    border-radius: 0 0 8px 8px
    max-height: 70vh
    overflow-y: auto

.modal h3
  font-size 18px
  font-weight 600
  margin 0.6em 0

#textureModal .modal-content
  height calc(100% - 50px)
  width calc(100% - 50px)

.modal-content
  background-color var(--color-base-200)
  box-shadow 0 4px 8px 0 rgba(0, 0, 0, 0.5), 0 6px 20px 0 rgba(0, 0, 0, 0.5)
  margin auto
  overflow hidden
  padding 0

.close
  color var(--color-base-content)
  float right
  font-size 28px
  font-weight bold

.close:hover,
.close:focus
  color var(--color-primary)
  cursor pointer
  text-decoration none

.modal-header
  color var(--color-base-content)
  padding 2px 16px

.modal-body
  color var(--color-base-content)
  overflow auto
  padding 16px

.modal-footer
  color var(--color-base-content)
  padding 2px 16px

/* Gallery */
.gallery
  background var(--color-base-200)
  display flex
  flex-wrap wrap
  margin 15px auto 0
  max-height calc(100vh - 370px)
  overflow auto
  padding 15px 3px 3px

.newimage .gallery
  padding 16px

.gallery li
  border-radius 2px
  box-shadow 0 0 6px rgba(0, 0, 0, 0.6)
  cursor pointer
  margin 8px
  overflow hidden
  width 155px

.gallery li.selected,
.gallery li:hover
  box-shadow 0 0 0 2px var(--color-primary)

.gallery li .detail
  background-color var(--color-base-100)
  margin 0
  min-height 60px
  padding 3px 10px

.preview
  padding 10px
  width 150px

.preview input
  display block
  margin 8px 0
  width 144px

.preview .iderror
  background unquote("color-mix(in oklab, var(--color-error) 8%, var(--color-base-300))")
  color var(--color-error)
  font-weight 600
  margin-bottom 8px
  padding 3px 5px
  text-align center
  width 148px

.preview button
  width 155px

.preview .detail .title
  color var(--color-base-content)
  display inline-block
  max-width 155px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.gallery li.selected .detail,
.gallery li:hover .detail
  background-color var(--color-base-lighter)

.gallery li .detail span
  color var(--color-base-content)
  display block
  margin-top 4px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  width 140px

.gallery li.selected .detail span,
.gallery li:hover .detail span
  color var(--color-base-content)

.gallery li .detail span.title
  color var(--color-property-defined)
  font-weight 600

.modal button
  appearance none
  background-color var(--color-primary)
  border none
  border-radius 0
  box-shadow none
  color var(--color-primary-content)
  cursor pointer
  display inline-block
  font-size 12px
  line-height 1.8
  margin 0 10px 0 0
  padding 5px 10px

.modal button:focus
  outline none

.modal button:hover,
.modal button.hover
  background-color var(--color-primary-hover)

.modal button:active,
.modal button.active
  background-color var(--color-primary-hover)

.modal button:disabled
  background-color #666
  color #fff
  cursor default

.newimage
  background-color var(--color-base-100)
  color var(--color-base-content)
  display flex
  font-size 13px
  justify-content space-between
  margin-top 10px
  overflow auto
  padding 10px

.newimage input
  color var(--color-primary)
  padding 3px 5px

.texture canvas + input
  margin-left 5px

.texture svg
  padding-right 5px

.uploader-normal-button .hidden
  display none

.assets.search
  margin-top 10px
  position relative
  width 200px

.assets.search input
  box-sizing border-box
  padding-right 20px
  width 100%

.assets.search svg
  position absolute
  right 5px
  top 5px

.new_asset_options
  margin 10px

.new_asset_options > ul
  margin-left 10px
  padding 5px

.new_asset_options > ul > li
  padding 10px 0

.new_asset_options .imageUrl
  margin-left 5px
  width 350px

.texture canvas
  border 1px solid var(--color-base-100)
  cursor pointer

/* Settings Modal Tabs */
.settings-tabs
  display flex
  border-bottom 1px solid var(--color-base-300)
  padding 0 10px

.settings-tab
  background transparent
  border none
  border-bottom 2px solid transparent
  color var(--color-base-content)
  cursor pointer
  display flex
  align-items center
  gap 8px
  font-size 14px
  padding 12px 20px
  transition all 0.2s

  &:hover
    color var(--color-primary)

  &.active
    border-bottom-color var(--color-primary)
    color var(--color-primary)

.settings-content
  padding 15px

/* Classes Tab */
.classes-tab
  .classes-header
    margin-bottom 20px

    h3
      color var(--color-primary)
      font-size 16px
      margin 0 0 8px

    p
      color var(--color-base-content)
      font-size 13px
      margin 0
      opacity 0.8

  .classes-actions
    display flex
    flex-wrap wrap
    gap 10px
    margin-bottom 20px

    .add-class-btn
      background var(--color-base-300)
      border none
      border-radius 4px
      color var(--color-base-content)
      cursor pointer
      display flex
      align-items center
      gap 6px
      padding 8px 12px
      font-size 12px
      transition all 0.2s

      &:hover
        background var(--color-primary)
        color var(--color-primary-content)

  .classes-list
    max-height 400px
    overflow-y auto

    .no-classes
      color var(--color-base-content)
      font-style italic
      opacity 0.6
      padding 20px
      text-align center

    ul
      list-style none
      margin 0
      padding 0

    .class-item
      align-items center
      background var(--color-base-300)
      border-radius 4px
      display flex
      justify-content space-between
      margin-bottom 8px
      padding 10px 15px

      .class-name
        color var(--color-primary)
        font-family 'Monaco', 'Menlo', monospace
        font-size 13px

      .class-count
        color var(--color-base-content)
        font-size 12px
        opacity 0.7
        margin-left 10px

      .class-item-actions
        display flex
        gap 8px
        flex-shrink 0

      .class-edit,
      .class-delete
        background transparent
        border none
        border-radius 4px
        color var(--color-base-content)
        cursor pointer
        padding 6px 8px
        transition all 0.2s

        &:hover
          background var(--color-base-100)

      .class-edit
        &:hover
          background var(--color-primary)
          color var(--color-primary-content)

      .class-delete
        &:hover
          background var(--color-error)
          color white

  .classes-help
    margin-top 20px
    padding 15px
    background var(--color-base-100)
    border-radius 4px

    p
      color var(--color-base-content)
      font-size 12px
      margin 0
      opacity 0.8

/* Models Tab */
.models-tab
  .models-header
    margin-bottom 20px

    h3
      color var(--color-primary)
      font-size 16px
      margin 0 0 8px

    p
      color var(--color-base-content)
      font-size 13px
      margin 0
      opacity 0.8

  .models-actions
    display flex
    flex-wrap wrap
    gap 10px
    margin-bottom 20px

    .add-model-btn
      background var(--color-base-300)
      border none
      border-radius 4px
      color var(--color-base-content)
      cursor pointer
      display flex
      align-items center
      gap 6px
      padding 8px 12px
      font-size 12px
      transition all 0.2s

      &:hover
        background var(--color-primary)
        color var(--color-primary-content)

  .models-list
    max-height 400px
    overflow-y auto

    .no-models
      color var(--color-base-content)
      font-style italic
      opacity 0.6
      padding 20px
      text-align center

    ul
      list-style none
      margin 0
      padding 0

    .model-item
      align-items center
      background var(--color-base-300)
      border-radius 4px
      display flex
      gap 12px
      margin-bottom 8px
      padding 12px 15px

      .model-icon
        color var(--color-primary)
        font-size 18px
        flex-shrink 0

      .model-info
        display flex
        flex-direction column
        gap 4px
        min-width 0

        .model-src
          color var(--color-primary)
          font-family 'Monaco', 'Menlo', monospace
          font-size 12px
          overflow hidden
          text-overflow ellipsis
          white-space nowrap

        .model-type
          color var(--color-base-content)
          font-size 11px
          opacity 0.7

      .model-actions
        display flex
        gap 8px
        flex-shrink 0

        .model-download,
        .model-delete
          background transparent
          border none
          border-radius 4px
          color var(--color-base-content)
          cursor pointer
          padding 6px 8px
          transition all 0.2s

          &:hover
            background var(--color-base-100)

        .model-delete
          &:hover
            background var(--color-error)
            color white

  .models-help
    margin-top 20px
    padding 15px
    background var(--color-base-100)
    border-radius 4px

    p
      color var(--color-base-content)
      font-size 12px
      margin 0
      opacity 0.8

